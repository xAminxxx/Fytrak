{
  "expo": {
    "name": "Fytrak",
    "owner": "xamin",
    "slug": "fytrak-mobile",
    "scheme": "fytrak",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/branding/raster/icon_main.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/branding/raster/logo_full_light.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.fytrak",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/branding/raster/icon_main.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-video",
      "expo-audio",
      "expo-image-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "d759b641-41b4-4726-a1a6-5293d48f3a36"
      }
    }
  }
}